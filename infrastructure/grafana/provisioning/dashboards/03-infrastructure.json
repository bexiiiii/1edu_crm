{
  "title": "1edu CRM — Infrastructure",
  "uid": "1edu-infra",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["1edu", "infrastructure"],
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL — Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\",datname=\"ondeedu_crm\",state=\"active\"}",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus" }
        },
        {
          "expr": "pg_stat_activity_count{job=\"postgres\",datname=\"ondeedu_crm\",state=\"idle\"}",
          "legendFormat": "Idle",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 2,
      "title": "PostgreSQL — Transactions/sec",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres\",datname=\"ondeedu_crm\"}[1m])",
          "legendFormat": "Commits/s",
          "datasource": { "type": "prometheus" }
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres\",datname=\"ondeedu_crm\"}[1m])",
          "legendFormat": "Rollbacks/s",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 3,
      "title": "PostgreSQL — DB Size",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=\"postgres\",datname=\"ondeedu_crm\"}",
          "legendFormat": "DB Size",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis — Connected Clients",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "redis_connected_clients{job=\"redis\"}",
          "legendFormat": "Clients",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 5,
      "title": "Redis — Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 7, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "datasource": { "type": "prometheus" }
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Max",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 6,
      "title": "Redis — Commands/sec",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 7, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{job=\"redis\"}[1m])",
          "legendFormat": "Commands/s",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 7,
      "title": "Redis — Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[1m]) / clamp_min(rate(redis_keyspace_hits_total{job=\"redis\"}[1m]) + rate(redis_keyspace_misses_total{job=\"redis\"}[1m]), 0.001)",
          "legendFormat": "Hit Rate",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 8,
      "title": "RabbitMQ — Messages Ready",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_ready{job=\"rabbitmq\"}",
          "legendFormat": "Ready",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 9,
      "title": "RabbitMQ — Messages Published vs Delivered/sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "rate(rabbitmq_channel_messages_published_total{job=\"rabbitmq\"}[1m])",
          "legendFormat": "Published/s",
          "datasource": { "type": "prometheus" }
        },
        {
          "expr": "rate(rabbitmq_channel_messages_delivered_total{job=\"rabbitmq\"}[1m])",
          "legendFormat": "Delivered/s",
          "datasource": { "type": "prometheus" }
        }
      ]
    },
    {
      "id": 10,
      "title": "RabbitMQ — Unacknowledged Messages",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_unacked{job=\"rabbitmq\"}",
          "legendFormat": "Unacked",
          "datasource": { "type": "prometheus" }
        }
      ]
    }
  ]
}
